# ─────────────────────────────────────────────────────────────
# Teman Berbagi — Environment Variables
# ─────────────────────────────────────────────────────────────
# Copy file ini menjadi .env dan isi sesuai konfigurasi kamu.
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# ── MongoDB Atlas (Cloud) ──
# Ganti <username>, <password>, <cluster>, dan <dbname> sesuai Atlas kamu.
# Contoh: mongodb+srv://john:rahasia123@cluster0.abc1234.mongodb.net/teman_berbagi
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/teman_berbagi?retryWrites=true&w=majority

# ── MongoDB Local (uncomment baris di bawah jika ingin pakai local) ──
# MONGO_URI=mongodb://127.0.0.1:27017/teman_berbagi

# ── Server ──
PORT=5000
NODE_ENV=development

# ── JWT ──
JWT_SECRET=teman-berbagi-secret-key-2026
JWT_EXPIRES_IN=7d
